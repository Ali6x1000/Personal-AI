# Copy to `.env` for Docker / ECS. Paths must exist INSIDE the container (not your Mac).
# After `COPY cred/ ./cred/` in the Dockerfile, keys live under `/app/cred/`.

GOOGLE_APPLICATION_CREDENTIALS=/app/cred/alijr.json

# LiveKit (same project for token API + agent worker)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# GCP project for Vertex / Gemini (match service account)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Embeddings (match how you built chroma_db)
EMBED_PROVIDER=gemini
